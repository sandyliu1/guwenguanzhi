{"而": ["用作连词。", "通“尔”，用作代词，第二人称，译为“你的”；偶尔也作主语，译为“你”。", "通“如”：好像，如同。"], "何": ["用作疑问代词。", "用作疑问副词。", "作语助词，相当于“啊”。", "何：通“呵”，喝问。"], "乎": ["用作语气助词。", "用作介词，相当于\"于\"，在文中有不同的翻译。", "可作词尾，译为“……的样子”“……地”。"], "乃": ["用作副词。", "用作代词。"], "其": ["用作代词，又分几种情况：", "用作副词。", "用作连词。", "助词，起调节音节的作用，可不译。"], "且": ["用作连词。", "用作副词。"], "若": ["动词，像，好像。", "用作代词。", "用作连词。"], "所": ["名词，处所，地方。", "助词"], "为": ["动词。", "介词。", "句末语气词，表示疑问或反诘。呢。"], "焉": ["兼词。", "代词。", "语气词。"], "也": ["句末语气词。", "句中语气词。用在句中，表示语气停顿。"], "以": ["介词", "连词。", "助词", "动词", "名词。译为：缘由，原因。", "通假"], "因": ["介词。", "副词。", "动词"], "于": ["介词。"], "与": ["介词。", "连词。", "动词。", "通假。通“欤”。句末语气词，表示感叹或疑问。"], "则": ["连词。", "副词。", "名词。", "动词。效法。", "通假。同“辄”，总是，常常。"], "者": ["助词。", "语气词。"], "之": ["代词。", "助词。", "动词，到……去。"]}
